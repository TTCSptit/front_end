<meta name="generator" content="Site Kit by Google 1.179.0" /><style id="vnpt-landing-global-css">
  :root {
    --vnpt-bg: #03081a;
    --vnpt-surface: #020626;
    --vnpt-card: #071033;
    --vnpt-border: #292f66;
    --vnpt-text: #ffffff;
    --vnpt-muted: #aab1f2;
    --vnpt-soft: #d9ddff;
    --vnpt-cyan: #05cee0;
    --vnpt-blue: #3d50fc;
    --vnpt-panel: #f5f6ff;
    --vnpt-dark: #020626;
    --vnpt-gradient: linear-gradient(90deg, rgb(5, 161, 201) 0%, rgb(61, 80, 252) 100%);
  }

  .vnpt-lp,
  .vnpt-lp * {
    box-sizing: border-box !important;
  }

  .vnpt-lp {
    font-family: Montserrat, Arial, Helvetica, sans-serif !important;
    color: var(--vnpt-text) !important;
    background:
      radial-gradient(circle at 15% 8%, rgba(5, 206, 224, .2), transparent 28%),
      radial-gradient(circle at 85% 3%, rgba(61, 80, 252, .28), transparent 34%),
      var(--vnpt-bg) !important;
    overflow: hidden !important;
  }

  .vnpt-lp a {
    text-decoration: none !important;
  }

  .vnpt-lp-container {
    width: min(1200px, calc(100% - 32px)) !important;
    margin: 0 auto !important;
  }

  .vnpt-lp-section {
    padding: 82px 0 !important;
    position: relative !important;
  }

  .vnpt-lp-hero {
    padding: 48px 0 88px !important;
    min-height: 760px !important;
  }

  .vnpt-lp-nav {
    position: sticky !important;
    top: 14px !important;
    z-index: 50 !important;
    display: flex !important;
    align-items: center !important;
    justify-content: space-between !important;
    gap: 20px !important;
    padding: 12px 14px !important;
    margin: 0 0 42px !important;
    border: 1px solid rgba(170,177,242,.18) !important;
    border-radius: 999px !important;
    background: rgba(3,8,26,.82) !important;
    backdrop-filter: blur(18px) !important;
    box-shadow: 0 18px 55px rgba(0,0,0,.28) !important;
  }

  .vnpt-lp-logo {
    display: inline-flex !important;
    align-items: center !important;
    gap: 10px !important;
    min-height: 48px !important;
    padding: 7px 14px 7px 8px !important;
    border-radius: 999px !important;
    background: rgba(255,255,255,.055) !important;
    color: #fff !important;
    font-size: 17px !important;
    font-weight: 800 !important;
    white-space: nowrap !important;
  }

  .vnpt-lp-logo-mark {
    width: 34px !important;
    height: 34px !important;
    border-radius: 12px !important;
    background: var(--vnpt-gradient) !important;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    color: #fff !important;
  }

  .vnpt-lp-navlinks {
    display: flex !important;
    gap: 8px !important;
    align-items: center !important;
    justify-content: center !important;
    padding: 6px !important;
    border: 1px solid rgba(170,177,242,.14) !important;
    border-radius: 999px !important;
    background: rgba(255,255,255,.045) !important;
  }

  .vnpt-lp-navlinks a {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    min-height: 42px !important;
    padding: 12px 18px !important;
    border: 1px solid rgba(170,177,242,.14) !important;
    border-radius: 999px !important;
    color: var(--vnpt-soft) !important;
    background: linear-gradient(180deg, rgba(255,255,255,.095), rgba(255,255,255,.035)) !important;
    font-size: 13px !important;
    font-weight: 800 !important;
    transition: all .25s ease !important;
  }

  .vnpt-lp-navlinks a:hover {
    color: #fff !important;
    transform: translateY(-2px) !important;
    border-color: rgba(5,206,224,.55) !important;
    background: var(--vnpt-gradient) !important;
    box-shadow: 0 12px 28px rgba(5,206,224,.18) !important;
  }

  .vnpt-lp-navlinks a.vnpt-hot {
    color: #fff !important;
    border-color: rgba(5,206,224,.55) !important;
    background: var(--vnpt-gradient) !important;
    box-shadow: 0 14px 34px rgba(61,80,252,.28) !important;
  }

  .vnpt-lp-navlinks a.vnpt-hot:after {
    content: "Hot" !important;
    margin-left: 8px !important;
    padding: 3px 7px !important;
    border-radius: 999px !important;
    color: #020626 !important;
    background: #05cee0 !important;
    font-size: 10px !important;
    font-weight: 900 !important;
  }

  .vnpt-lp-btn {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    min-height: 52px !important;
    padding: 14px 26px !important;
    border-radius: 999px !important;
    font-size: 15px !important;
    line-height: 1.2 !important;
    font-weight: 700 !important;
    transition: all .25s ease !important;
  }

  .vnpt-lp-btn:hover {
    transform: translateY(-2px) !important;
  }

  .vnpt-lp-btn-primary {
    color: #fff !important;
    border: 0 !important;
    background: var(--vnpt-gradient) !important;
    box-shadow: 0 18px 60px rgba(61, 80, 252, .32) !important;
  }

  .vnpt-lp-btn-secondary {
    color: #fff !important;
    border: 1px solid rgba(170,177,242,.35) !important;
    background: rgba(255,255,255,.04) !important;
  }

  .vnpt-lp-btns {
    display: flex !important;
    flex-wrap: wrap !important;
    gap: 14px !important;
    margin-top: 30px !important;
  }

  .vnpt-lp-eyebrow {
    display: inline-flex !important;
    align-items: center !important;
    gap: 9px !important;
    padding: 10px 16px !important;
    border: 1px solid rgba(170,177,242,.28) !important;
    border-radius: 999px !important;
    color: var(--vnpt-soft) !important;
    background: rgba(8,15,77,.58) !important;
    font-size: 12px !important;
    font-weight: 700 !important;
    letter-spacing: .16em !important;
    text-transform: uppercase !important;
  }

  .vnpt-lp-eyebrow:before {
    content: "" !important;
    width: 8px !important;
    height: 8px !important;
    border-radius: 50% !important;
    background: var(--vnpt-gradient) !important;
    box-shadow: 0 0 20px rgba(5,206,224,.9) !important;
  }

  .vnpt-lp-title {
    margin: 18px 0 14px !important;
    color: #fff !important;
    font-size: clamp(34px, 5vw, 72px) !important;
    line-height: .98 !important;
    letter-spacing: -.04em !important;
    font-weight: 400 !important;
  }

  .vnpt-lp-title span,
  .vnpt-lp-gradient-text {
    background: var(--vnpt-gradient) !important;
    -webkit-background-clip: text !important;
    background-clip: text !important;
    color: transparent !important;
  }

  .vnpt-lp-subtitle,
  .vnpt-lp-lead,
  .vnpt-lp-microcopy {
    color: var(--vnpt-muted) !important;
  }

  .vnpt-lp-subtitle {
    font-size: 17px !important;
    line-height: 1.75 !important;
    max-width: 720px !important;
    margin: 0 !important;
  }

  .vnpt-lp-microcopy {
    font-size: 13px !important;
    line-height: 1.6 !important;
    margin-top: 14px !important;
  }

  .vnpt-lp-hero-grid,
  .vnpt-lp-grid-2 {
    display: grid !important;
    grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
    gap: 48px !important;
    align-items: center !important;
  }

  .vnpt-lp-grid-3 {
    display: grid !important;
    grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
    gap: 22px !important;
  }

  .vnpt-lp-grid-4 {
    display: grid !important;
    grid-template-columns: repeat(4, minmax(0, 1fr)) !important;
    gap: 16px !important;
  }

  .vnpt-lp-card {
    border: 1px solid rgba(170,177,242,.18) !important;
    border-radius: 34px !important;
    background: rgba(2,6,38,.78) !important;
    padding: 32px !important;
    color: #fff !important;
  }

  .vnpt-lp-card h3 {
    margin: 0 0 10px !important;
    color: #fff !important;
    font-size: 22px !important;
    line-height: 1.25 !important;
    font-weight: 700 !important;
  }

  .vnpt-lp-card p,
  .vnpt-lp-card li {
    color: var(--vnpt-muted) !important;
    font-size: 14px !important;
    line-height: 1.7 !important;
    margin: 0 !important;
  }

  .vnpt-lp-card-light {
    background: #fff !important;
    color: var(--vnpt-dark) !important;
    border-color: rgba(41,47,102,.1) !important;
  }

  .vnpt-lp-card-light h3,
  .vnpt-lp-card-light p,
  .vnpt-lp-card-light li {
    color: var(--vnpt-dark) !important;
  }

  .vnpt-lp-section-head {
    max-width: 790px !important;
    margin-bottom: 34px !important;
  }

  .vnpt-lp-center {
    text-align: center !important;
    margin-left: auto !important;
    margin-right: auto !important;
  }

  .vnpt-lp-h2 {
    margin: 16px 0 12px !important;
    font-size: clamp(30px, 4vw, 54px) !important;
    line-height: 1.05 !important;
    letter-spacing: -.035em !important;
    font-weight: 400 !important;
    color: #fff !important;
  }

  .vnpt-lp-lead {
    font-size: 16px !important;
    line-height: 1.75 !important;
    margin: 0 !important;
  }

  .vnpt-lp-light {
    background: var(--vnpt-panel) !important;
    color: var(--vnpt-dark) !important;
  }

  .vnpt-lp-light .vnpt-lp-h2 {
    color: var(--vnpt-dark) !important;
  }

  .vnpt-lp-light .vnpt-lp-lead {
    color: #4d5499 !important;
  }

  .vnpt-lp-list {
    margin: 0 !important;
    padding: 0 !important;
    list-style: none !important;
  }

  .vnpt-lp-list li {
    position: relative !important;
    padding-left: 28px !important;
    margin-bottom: 13px !important;
  }

  .vnpt-lp-list li:before {
    content: "✓" !important;
    position: absolute !important;
    left: 0 !important;
    top: 0 !important;
    color: var(--vnpt-cyan) !important;
    font-weight: 900 !important;
  }

  .vnpt-lp-stats {
    display: grid !important;
    grid-template-columns: repeat(4, minmax(0, 1fr)) !important;
    gap: 16px !important;
    margin-top: 38px !important;
  }

  .vnpt-lp-stat {
    border: 1px solid rgba(170,177,242,.2) !important;
    border-radius: 24px !important;
    background: rgba(255,255,255,.035) !important;
    padding: 22px !important;
  }

  .vnpt-lp-stat strong {
    display: block !important;
    color: #fff !important;
    font-size: 25px !important;
    line-height: 1 !important;
    margin-bottom: 8px !important;
  }

  .vnpt-lp-stat span {
    color: var(--vnpt-muted) !important;
    font-size: 13px !important;
    line-height: 1.45 !important;
  }

  .vnpt-lp-icon {
    width: 48px !important;
    height: 48px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    border-radius: 18px !important;
    background: rgba(5,206,224,.1) !important;
    border: 1px solid rgba(5,206,224,.2) !important;
    color: var(--vnpt-cyan) !important;
    font-size: 24px !important;
    margin-bottom: 20px !important;
  }

  .vnpt-lp-dashboard {
    position: relative !important;
    border: 1px solid rgba(170,177,242,.18) !important;
    border-radius: 38px !important;
    background:
      linear-gradient(145deg, rgba(255,255,255,.08), rgba(255,255,255,.02)),
      radial-gradient(circle at top right, rgba(5,206,224,.32), transparent 33%),
      rgba(2,6,38,.72) !important;
    padding: 26px !important;
    overflow: hidden !important;
  }

  .vnpt-lp-mockup {
    max-width: 430px !important;
    margin: 40px auto !important;
    border-radius: 28px !important;
    background: rgba(255,255,255,.96) !important;
    color: var(--vnpt-dark) !important;
    padding: 20px !important;
    box-shadow: 0 30px 80px rgba(0,0,0,.35) !important;
  }

  .vnpt-lp-row {
    display: grid !important;
    grid-template-columns: 42px 1fr auto !important;
    gap: 12px !important;
    align-items: center !important;
    padding: 13px !important;
    border-radius: 18px !important;
    background: #f5f6ff !important;
    margin-bottom: 10px !important;
  }

  .vnpt-lp-row strong {
    display: block !important;
    color: #020626 !important;
    font-size: 13px !important;
    margin-bottom: 3px !important;
  }

  .vnpt-lp-row span {
    color: #4d5499 !important;
    font-size: 11px !important;
  }

  .vnpt-lp-doc {
    width: 42px !important;
    height: 42px !important;
    border-radius: 15px !important;
    background: #e8ebff !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    font-size: 20px !important;
  }

  .vnpt-lp-status {
    color: #fff !important;
    padding: 7px 10px !important;
    border-radius: 999px !important;
    background: #05a1c9 !important;
    font-size: 11px !important;
    font-weight: 800 !important;
    white-space: nowrap !important;
  }

  .vnpt-lp-status-blue {
    background: #3d50fc !important;
  }

  .vnpt-lp-price-wrap {
    overflow-x: auto !important;
    border-radius: 28px !important;
    border: 1px solid rgba(41,47,102,.14) !important;
    background: #fff !important;
  }

  .vnpt-lp-price-table {
    width: 100% !important;
    min-width: 760px !important;
    border-collapse: collapse !important;
    color: var(--vnpt-dark) !important;
    background: #fff !important;
  }

  .vnpt-lp-price-table th,
  .vnpt-lp-price-table td {
    padding: 18px !important;
    border-bottom: 1px solid #e6e8ff !important;
    font-size: 14px !important;
    text-align: left !important;
  }

  .vnpt-lp-price-table th {
    color: #fff !important;
    background: #020626 !important;
    font-weight: 800 !important;
  }

  .vnpt-lp-price-table tr.highlight td {
    background: #eef2ff !important;
    font-weight: 800 !important;
  }

  .vnpt-lp-badge {
    display: inline-flex !important;
    padding: 8px 12px !important;
    border-radius: 999px !important;
    color: #fff !important;
    background: var(--vnpt-gradient) !important;
    font-size: 12px !important;
    font-weight: 800 !important;
    white-space: nowrap !important;
  }

  .vnpt-lp-note {
    margin-top: 18px !important;
    color: #4d5499 !important;
    font-size: 13px !important;
    line-height: 1.6 !important;
  }

  .vnpt-lp-faq details {
    border: 1px solid rgba(170,177,242,.18) !important;
    background: rgba(2,6,38,.78) !important;
    border-radius: 22px !important;
    padding: 18px 22px !important;
    margin-bottom: 12px !important;
  }

  .vnpt-lp-faq summary {
    cursor: pointer !important;
    color: #fff !important;
    font-size: 16px !important;
    font-weight: 800 !important;
  }

  .vnpt-lp-faq p {
    color: var(--vnpt-muted) !important;
    font-size: 14px !important;
    line-height: 1.7 !important;
    margin: 12px 0 0 !important;
  }

  .vnpt-lp-final {
    border-radius: 42px !important;
    padding: 48px !important;
    background:
      radial-gradient(circle at 15% 20%, rgba(5,206,224,.24), transparent 30%),
      linear-gradient(135deg, #020626 0%, #080f4d 52%, #03081a 100%) !important;
    border: 1px solid rgba(170,177,242,.22) !important;
  }

  .vnpt-lp-form {
    background: #fff !important;
    border-radius: 30px !important;
    padding: 26px !important;
    color: var(--vnpt-dark) !important;
  }

  .vnpt-lp-form h3 {
    color: var(--vnpt-dark) !important;
    margin: 0 0 14px !important;
    font-size: 22px !important;
  }

  .vnpt-lp-form-grid {
    display: grid !important;
    grid-template-columns: 1fr 1fr !important;
    gap: 12px !important;
  }

  .vnpt-lp-form input,
  .vnpt-lp-form select,
  .vnpt-lp-form textarea {
    width: 100% !important;
    border: 1px solid #dfe3ff !important;
    border-radius: 16px !important;
    padding: 13px 14px !important;
    min-height: 48px !important;
    font-size: 14px !important;
    background: #f8f9ff !important;
    color: #020626 !important;
  }

  .vnpt-lp-form textarea {
    grid-column: 1 / -1 !important;
    min-height: 96px !important;
  }

  .vnpt-lp-sticky {
    position: fixed !important;
    z-index: 999 !important;
    left: 50% !important;
    bottom: 18px !important;
    transform: translateX(-50%) !important;
    display: flex !important;
    gap: 10px !important;
    padding: 10px !important;
    border-radius: 999px !important;
    border: 1px solid rgba(170,177,242,.2) !important;
    background: rgba(3,8,26,.84) !important;
    backdrop-filter: blur(14px) !important;
    box-shadow: 0 18px 50px rgba(0,0,0,.25) !important;
  }

  .vnpt-lp-sticky .vnpt-lp-btn {
    min-height: 42px !important;
    padding: 11px 18px !important;
    font-size: 13px !important;
  }

  @media (max-width: 980px) {
    .vnpt-lp-hero-grid,
    .vnpt-lp-grid-2,
    .vnpt-lp-grid-3 {
      grid-template-columns: 1fr !important;
    }

    .vnpt-lp-grid-4,
    .vnpt-lp-stats {
      grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
    }

    .vnpt-lp-nav {
      align-items: stretch !important;
      border-radius: 30px !important;
      flex-wrap: wrap !important;
    }

    .vnpt-lp-navlinks {
      display: grid !important;
      grid-template-columns: repeat(4, minmax(0, 1fr)) !important;
      order: 3 !important;
      width: 100% !important;
      border-radius: 22px !important;
    }

    .vnpt-lp-navlinks a {
      min-height: 40px !important;
      padding: 10px 8px !important;
      font-size: 12px !important;
    }
  }

  @media (max-width: 640px) {
    .vnpt-lp-section {
      padding: 58px 0 !important;
    }

    .vnpt-lp-title {
      font-size: 42px !important;
    }

    .vnpt-lp-h2 {
      font-size: 34px !important;
    }

    .vnpt-lp-grid-4,
    .vnpt-lp-stats,
    .vnpt-lp-form-grid {
      grid-template-columns: 1fr !important;
    }

    .vnpt-lp-card,
    .vnpt-lp-final {
      padding: 24px !important;
      border-radius: 26px !important;
    }

    .vnpt-lp-sticky {
      width: calc(100% - 24px) !important;
      justify-content: center !important;
    }
  }
</style>
